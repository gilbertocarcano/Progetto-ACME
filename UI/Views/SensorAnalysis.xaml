<Window
    x:Class="AcmeUI.Views.SensorAnalysis"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AcmeUI.Models"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    Title="Sensor Analysis">

    <Grid x:Name="RootGrid" Padding="20">

        <Grid.Resources>

            <Style x:Key="CompactTableCell" TargetType="Border">
                <Setter Property="Padding" Value="2"/>
                <Setter Property="BorderBrush" Value="Gray"/>
                <Setter Property="BorderThickness" Value="0.5"/>
            </Style>

            <Style TargetType="ListViewItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!--     COLONNA SINISTRA      -->
        <!-- ========================= -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Spacing="20">

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Corrente massima [mA]" />
                    <NumberBox
                        Value="{Binding MaxCurrent, Mode=TwoWay}"
                        Minimum="0"
                        SpinButtonPlacementMode="Inline"/>
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Step di corrente [mA]" />
                    <NumberBox
                        Value="{Binding CurrentStep, Mode=TwoWay}"
                        Minimum="0"
                        SpinButtonPlacementMode="Inline"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Avvia analisi"
                            Command="{Binding StartAnalysisCommand}"/>

                    <Button Content="Abort"
                            Background="#FFF44336"
                            Foreground="White"
                            Command="{Binding AbortCommand}"/>
                </StackPanel>

                <!-- TABELLA -->
                <StackPanel>

                    <Grid ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="0">
                            <TextBlock Text="I(mA)" FontWeight="Bold" FontSize="10"/>
                        </Border>
                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="1">
                            <TextBlock Text="Vsx(V)" FontWeight="Bold" FontSize="10"/>
                        </Border>
                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="2">
                            <TextBlock Text="Vdx(V)" FontWeight="Bold" FontSize="10"/>
                        </Border>
                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="3">
                            <TextBlock Text="Vup(V)" FontWeight="Bold" FontSize="10"/>
                        </Border>
                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="4">
                            <TextBlock Text="Vdw(V)" FontWeight="Bold" FontSize="10"/>
                        </Border>
                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="5">
                            <TextBlock Text="Vc(V)" FontWeight="Bold" FontSize="10"/>
                        </Border>
                    </Grid>

                    <ListView ItemsSource="{Binding CalibrationRows}"
                              BorderThickness="0"
                              Margin="0">

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ScanRow">

                                <Grid ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource CompactTableCell}" Grid.Column="0">
                                        <TextBlock Text="{Binding Position}" FontSize="10" HorizontalAlignment="Right"/>
                                    </Border>

                                    <Border Style="{StaticResource CompactTableCell}" Grid.Column="1">
                                        <TextBlock Text="{Binding V1}" FontSize="10" HorizontalAlignment="Right"/>
                                    </Border>

                                    <Border Style="{StaticResource CompactTableCell}" Grid.Column="2">
                                        <TextBlock Text="{Binding V2}" FontSize="10" HorizontalAlignment="Right"/>
                                    </Border>

                                    <Border Style="{StaticResource CompactTableCell}" Grid.Column="3">
                                        <TextBlock Text="{Binding V3}" FontSize="10" HorizontalAlignment="Right"/>
                                    </Border>

                                    <Border Style="{StaticResource CompactTableCell}" Grid.Column="4">
                                        <TextBlock Text="{Binding V4}" FontSize="10" HorizontalAlignment="Right"/>
                                    </Border>

                                    <Border Style="{StaticResource CompactTableCell}" Grid.Column="5">
                                        <TextBlock Text="{Binding V5}" FontSize="10" HorizontalAlignment="Right"/>
                                    </Border>
                                </Grid>

                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                </StackPanel>

            </StackPanel>

        </ScrollViewer>

        <!-- ========================= -->
        <!--     COLONNA DESTRA        -->
        <!-- ========================= -->
        <Grid Grid.Column="1">

            <lvc:CartesianChart
                Series="{Binding ChartSeries}"
                XAxes="{Binding ChartXAxes}"
                YAxes="{Binding ChartYAxes}"
                LegendPosition="Right"
                ZoomMode="None"/>
        </Grid>

    </Grid>

</Window>
