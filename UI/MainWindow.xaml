<Window
    x:Class="AcmeUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AcmeUI.Models"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <Grid x:Name="RootGrid" Padding="0" Loaded="RootGrid_Loaded">

        <!-- ========================= -->
        <!--      RISORSE GLOBALI      -->
        <!-- ========================= -->
        <Grid.Resources>

            <!-- Pulsanti stile HMI -->
            <Style x:Key="HmiButtonBase" TargetType="Button">
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="Height" Value="70"/>
                <Setter Property="Margin" Value="0,8,0,8"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Foreground" Value="Black"/>
            </Style>

            <Style x:Key="HmiButtonHome" TargetType="Button" BasedOn="{StaticResource HmiButtonBase}">
                <Setter Property="Background" Value="#FFDDDDDD"/>
                <!-- grigio -->
            </Style>

            <Style x:Key="HmiButtonScan" TargetType="Button" BasedOn="{StaticResource HmiButtonBase}">
                <Setter Property="Background" Value="#FF4CAF50"/>
                <!-- verde -->
            </Style>

            <Style x:Key="HmiButtonAbort" TargetType="Button" BasedOn="{StaticResource HmiButtonBase}">
                <Setter Property="Background" Value="#FFF44336"/>
                <!-- rosso -->
            </Style>

            <!-- Tabella compatta -->
            <Style x:Key="CompactTableCell" TargetType="Border">
                <Setter Property="Padding" Value="2"/>
                <Setter Property="BorderBrush" Value="Gray"/>
                <Setter Property="BorderThickness" Value="0.5"/>
            </Style>
            <Style TargetType="ListViewItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

        </Grid.Resources>

        <!-- ========================= -->
        <!--        STRUTTURA UI       -->
        <!-- ========================= -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="*"/>
            <!-- Dashboard -->
        </Grid.RowDefinitions>

        <!-- MENU BAR -->
        <MenuBar Grid.Row="0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Salva CSV" Click="OnSaveCsvClick" />
                <MenuFlyoutItem Text="Apri CSV" Click="OnOpenCsvClick" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Esci" Click="OnExitClick" />
            </MenuBarItem>

            <MenuBarItem Title="Impostazioni">
                <MenuFlyoutItem Text="Funzionamento Sistema" Click="OnSystemSettingsClick" />
                <MenuFlyoutItem Text="Impostazioni Locali" Click="OnLocalSettingsClick" />
            </MenuBarItem>
            
            <MenuBarItem Title="Strumenti">
                <MenuFlyoutItem Text="Caratteristiche sensori" Click="OnSensorAnalysisClick" />
            </MenuBarItem>
        </MenuBar>

        <!-- ========================= -->
        <!--        DASHBOARD 3 COL    -->
        <!-- ========================= -->
        <Grid Grid.Row="1" Padding="20" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <!-- 30% -->
                <ColumnDefinition Width="2*"/>
                <!-- 20% -->
                <ColumnDefinition Width="5*"/>
                <!-- 50% -->
            </Grid.ColumnDefinitions>

            <!-- ========================= -->
            <!--   COLONNA 1: PULSANTI    -->
            <!-- ========================= -->
            <StackPanel Grid.Column="0" Spacing="16">

                <!-- Pulsanti HOME / SCAN / ABORT sulla stessa riga -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"               
                Style="{StaticResource HmiButtonHome}"
                Command="{Binding GoHomeCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE80F;" 
                  FontFamily="Segoe Fluent Icons"
                  FontSize="20"/>
                            <TextBlock Text="HOME"
                   FontSize="18"
                   FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1"
        Style="{StaticResource HmiButtonScan}"
        Command="{Binding StartScanCommand}">

                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE768;" 
                  FontFamily="Segoe Fluent Icons"
                  FontSize="20"/>
                            <TextBlock Text="SCAN"
                   FontSize="18"
                   FontWeight="Bold"/>
                        </StackPanel>

                    </Button>

                    <Button Grid.Column="2"
        Style="{StaticResource HmiButtonAbort}"
        Command="{Binding AbortCommand}">

                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE71A;" 
                  FontFamily="Segoe Fluent Icons"
                  FontSize="20"/>
                            <TextBlock Text="ABORT"
                   FontSize="18"
                   FontWeight="Bold"/>
                        </StackPanel>

                    </Button>


                </Grid>

                <Border Height="1" Background="Gray" Margin="0,10,0,10"/>

                <!-- Pulsanti POSIZIONE: Iniziale — Centro — Finale -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
        Style="{StaticResource HmiButtonHome}"
        Command="{Binding GoStartCommand}">

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icona -->
                            <FontIcon Glyph="&#xE72B;"
                  FontFamily="Segoe Fluent Icons"
                  FontSize="20"
                  VerticalAlignment="Center"/>

                            <!-- Testo che va a capo -->
                            <TextBlock Grid.Column="1"
                   Text="Posizione iniziale"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   FontSize="16"
                   FontWeight="Bold"/>
                        </Grid>

                    </Button>


                    <Button Grid.Column="1"
        Style="{StaticResource HmiButtonHome}"
        Command="{Binding GoZeroCommand}">

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icona centro -->
                            <FontIcon Glyph="&#xe974;"
                  FontFamily="Segoe Fluent Icons"
                  FontSize="20"
                  VerticalAlignment="Center"/>

                            <!-- Testo -->
                            <TextBlock Grid.Column="1"
                   Text="Centro"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   FontSize="16"
                   FontWeight="Bold"/>

                            <!-- Icona centro -->
                            <FontIcon Grid.Column="2" Glyph="&#xe973;"
FontFamily="Segoe Fluent Icons"
FontSize="20"
VerticalAlignment="Center"/>

                        </Grid>

                    </Button>


                    <Button Grid.Column="2"
        Style="{StaticResource HmiButtonHome}"
        Command="{Binding GoEndCommand}">

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>



                            <!-- Testo che va a capo -->
                            <TextBlock 
                   Text="Posizione finale"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   FontSize="16"
                   FontWeight="Bold"/>

                            <!-- Icona: freccia che rientra verso destra -->
                            <FontIcon Grid.Column="1" Glyph="&#xE72A;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="20"
                                VerticalAlignment="Center"/>
                        </Grid>

                    </Button>

                </Grid>

                <!-- Valori sotto i pulsanti -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Valore posizione iniziale -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="3">
                        <TextBlock Text="{Binding StartPosition}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="mm" FontSize="12" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <!-- Valore centro -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="3">
                        <TextBlock Text="{Binding CenterPosition}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="mm" FontSize="12" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <!-- Valore posizione finale -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="3">
                        <TextBlock Text="{Binding EndPosition}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="mm" FontSize="12" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Grid>


                <Border Height="1" Background="Gray" Margin="0,10,0,10"/>

                <!-- Stato e posizione attuale -->
                <StackPanel Spacing="6">

                    <!-- STATO -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Stato:" 
                   FontSize="18" 
                   FontWeight="Normal"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Status}" 
                   FontSize="24" 
                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- POSIZIONE ATTUALE -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Posizione:" 
                   FontSize="18" 
                   FontWeight="Normal"
                                   VerticalAlignment="Center"/>

                        <!-- valore + mm -->
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="{Binding Position}" 
                       FontSize="24" 
                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="mm" 
                       FontSize="14" 
                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- POSIZIONE ASSOLUTA -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Posizione assoluta:" 
                   FontSize="18" 
                   Foreground="Gray"
                                   VerticalAlignment="Center"/>

                        <!-- valore + mm -->
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="{Binding MachinePosition}" 
                       FontSize="18" 
                       Foreground="Gray"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="mm" 
                       FontSize="14" 
                       Foreground="Gray"
                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <Border Height="1" Background="Gray" Margin="0,10,0,10"/>

                <!-- ========================= -->
                <!--   MINI GRAFICI INTB      -->
                <!-- ========================= -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Grafico IntB -->
                    <StackPanel Grid.Column="0" Spacing="1">
                        <TextBlock Text="IntB (gauss*mm)"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,-10,0,0"/>
                        <lvc:CartesianChart
                            x:Name="IntBChart"
                            Series="{Binding IntBSeries}"
                            XAxes="{Binding IntBXAxis}"
                            YAxes="{Binding MiniYAxis}"
                            LegendPosition="Hidden"
                            Height="200"                            
                            ZoomMode="None"/>
                    </StackPanel>

                    <!-- Grafico DeltaIntB -->
                    <StackPanel Grid.Column="1" Spacing="1">
                        <TextBlock Text="Δ IntB"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,-10,0,0"/>
                        <lvc:CartesianChart
                            x:Name="DeltaIntBChart"
                            Series="{Binding DeltaIntBSeries}"
                            XAxes="{Binding DeltaIntBXAxis}"
                            YAxes="{Binding MiniYAxis}"
                            LegendPosition="Hidden"
                            Height="200"                            
                            ZoomMode="None"/>
                    </StackPanel>
                </Grid>



            </StackPanel>



            <!-- ========================= -->
            <!--   COLONNA 2: TABELLA     -->
            <!-- ========================= -->
            <Border Grid.Column="1"
                    
                    Padding="5,8,5,5">

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <!-- Intestazioni -->
                        <Grid ColumnSpacing="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CompactTableCell}" Grid.Column="0">
                                <TextBlock Text="Z(mm)" FontWeight="Bold" FontSize="10"/>
                            </Border>
                            <Border Style="{StaticResource CompactTableCell}" Grid.Column="1">
                                <TextBlock Text="Bsx(g)" FontWeight="Bold" FontSize="10"/>
                            </Border>
                            <Border Style="{StaticResource CompactTableCell}" Grid.Column="2">
                                <TextBlock Text="Bdx(g)" FontWeight="Bold" FontSize="10"/>
                            </Border>
                            <Border Style="{StaticResource CompactTableCell}" Grid.Column="3">
                                <TextBlock Text="Bup(g)" FontWeight="Bold" FontSize="10"/>
                            </Border>
                            <Border Style="{StaticResource CompactTableCell}" Grid.Column="4">
                                <TextBlock Text="Bdw(g)" FontWeight="Bold" FontSize="10"/>
                            </Border>
                            <Border Style="{StaticResource CompactTableCell}" Grid.Column="5">
                                <TextBlock Text="B0(g)" FontWeight="Bold" FontSize="10"/>
                            </Border>
                        </Grid>

                        <!-- Righe -->
                        <ListView ItemsSource="{Binding ScanRows}"
                                  BorderThickness="0"
                                  Margin="0">

                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ScanRow">

                                    <Grid ColumnSpacing="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="0"
                                            Background="{Binding IsInHRRange, Converter={StaticResource BoolToBrushConverter}}">
                                            <TextBlock Text="{Binding Position}" FontSize="10" HorizontalAlignment="Right"/>
                                        </Border>
                                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="1">
                                            <TextBlock Text="{Binding B1}" FontSize="10" HorizontalAlignment="Right"/>
                                        </Border>
                                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="2">
                                            <TextBlock Text="{Binding B2}" FontSize="10" HorizontalAlignment="Right"/>
                                        </Border>
                                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="3">
                                            <TextBlock Text="{Binding B3}" FontSize="10" HorizontalAlignment="Right"/>
                                        </Border>
                                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="4">
                                            <TextBlock Text="{Binding B4}" FontSize="10" HorizontalAlignment="Right"/>
                                        </Border>
                                        <Border Style="{StaticResource CompactTableCell}" Grid.Column="5">
                                            <TextBlock Text="{Binding B5}" FontSize="10" HorizontalAlignment="Right"/>
                                        </Border>
                                    </Grid>

                                </DataTemplate>
                            </ListView.ItemTemplate>

                        </ListView>

                        <!-- ========================= -->
                        <!--   PULSANTE FIT GAUSSIANO  -->
                        <!-- ========================= -->
                        <Button Content="FIT GAUSSIANO"
                            Margin="0,10,0,0"
                            Height="40"
                            FontSize="16"
                            HorizontalAlignment="Stretch"
                            Command="{Binding NormalizeCurvesCommand}"
                            Background="#FF4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            IsEnabled="{Binding IsDataReady}"/>

                    </StackPanel>

                </ScrollViewer>

            </Border>

            <!-- ========================= -->
            <!--   COLONNA 3: GRAFICO     -->
            <!-- ========================= -->
            <Grid Grid.Column="2">
                <lvc:CartesianChart
                    Series="{Binding ChartSeries}"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}"
                    LegendPosition="Right"
                    ZoomMode="None"/>
            </Grid>

        </Grid>

    </Grid>
</Window>
